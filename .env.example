# Copy this file to .env and fill in your API key(s):
#   cp .env.example .env
#
# Get an Anthropic API key at https://console.anthropic.com/settings/keys
# (Claude Max subscription does not include API access.)

# Required for Claude (default when SCREEN_AGENT_PROVIDER=auto or anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-8

# Optional OpenAI fallback (used when SCREEN_AGENT_PROVIDER=openai or auto with no Anthropic key)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Provider: auto | anthropic | openai
# auto = use Anthropic if ANTHROPIC_API_KEY is set, else OpenAI if OPENAI_API_KEY is set
SCREEN_AGENT_PROVIDER=auto

# Server bind address and port
SCREEN_AGENT_HOST=127.0.0.1
SCREEN_AGENT_PORT=8766
